title: $:/themes/tiddlywiki/opaline/tiddlydesktop
tags: [[$:/tags/Stylesheet]]

\rules only filteredtranscludeinline transcludeinline macrodef macrocallinline

/*
** TiddlyDesktop — Opaline theme
** Milky opal-glass aesthetic: smooth pebble shapes, accent-tinted shadows,
** luminous toolbar. The wiki list feels like floating frosted-glass cards.
*/

/* Toolbar — primary-coloured, matching the Opaline menubar; accent-tinted shadow */
.td-toolbar {
	background: <<colour wikilist-toolbar-background>>;
	color: <<colour wikilist-toolbar-foreground>>;
	box-shadow: var(--o-shadow-1);
	font-family: var(--o-body);
}

/* Page background — ambient glow pools matching the Opaline wiki */
body {
	background-image:
		radial-gradient(48% 40% at 12% 4%, color-mix(in srgb, var(--o-iris-2) 22%, transparent), transparent 62%),
		radial-gradient(40% 34% at 90% 12%, color-mix(in srgb, var(--o-iris-4) 20%, transparent), transparent 60%),
		radial-gradient(44% 40% at 86% 92%, color-mix(in srgb, var(--o-iris-3) 18%, transparent), transparent 62%),
		radial-gradient(50% 46% at 30% 100%, color-mix(in srgb, var(--o-iris-5) 16%, transparent), transparent 64%);
	background-attachment: fixed;
	background-repeat: no-repeat;
}

/* Wiki-list items — iridescent opal-glass cards with animated border */
.td-wikilist .td-wikilist-item {
	--o-angle: 130deg;
	border: 2px solid transparent;
	border-radius: var(--o-radius);
	background:
		radial-gradient(120% 90% at 0% 0%, color-mix(in srgb, var(--o-iris-2) 10%, transparent), transparent 50%) padding-box,
		radial-gradient(120% 90% at 100% 100%, color-mix(in srgb, var(--o-iris-4) 8%, transparent), transparent 50%) padding-box,
		linear-gradient(var(--o-paper), var(--o-paper)) padding-box,
		var(--o-iris) border-box;
	box-shadow: var(--o-shadow-1);
	transition: box-shadow var(--o-slow) var(--o-ease),
		--o-angle 1100ms var(--o-ease);
}
.td-wikilist .td-wikilist-item:hover {
	--o-angle: 490deg;
	box-shadow: var(--o-shadow-2);
}
.td-wikilist .td-wikilist-item.tc-dragging {
	--o-angle: 130deg;
	box-shadow: none;
}

/* Title — Opaline's luminous humanist display face */
.td-wikilist .td-wiki-title {
	font-family: var(--o-display);
	font-weight: 600;
}
.td-wikilist .td-wikilist-info {
	font-family: var(--o-body);
}

/* Buttons — pill-shaped to match Opaline's rounded, pebble-like aesthetic */
button.td-button {
	border-radius: var(--o-radius-pill);
	color: <<colour wikilist-button-foreground>>;
	font-family: var(--o-body);
	font-size: 0.82em;
	font-weight: 500;
	transition: background-color var(--o-fast) var(--o-ease);
}

/* Toolbar inputs */
.td-toolbar input,
.td-toolbar select {
	font-family: var(--o-body);
	border-radius: var(--o-radius-sm);
}

/* ── The WikiList window — frosted opal surface ─────────────────────── */
.td-search input.td-wikilist-search-input {
	font-family: var(--o-body);
	border-radius: var(--o-radius-pill);
	border: 1px solid var(--o-rule-strong);
	transition: box-shadow var(--o-dur) var(--o-ease);
}
.td-search input.td-wikilist-search-input:focus {
	box-shadow: 0 0 0 3px var(--o-wash-strong);
}
.td-tags .tc-tag-label {
	font-family: var(--o-body);
}

/* ── WikiList rows — pebble-framed favicon, luminous heading ─────────── */
.td-wikilist .td-wikilist-item .td-wikilist-thumbnail button {
	border-radius: var(--o-radius-sm);
	box-shadow: var(--o-shadow-1);
	overflow: hidden;
}
.td-wikilist .td-wiki-url {
	font-family: var(--o-body);
}
.td-wikilist .td-wiki-advanced-heading {
	font-family: var(--o-display);
}

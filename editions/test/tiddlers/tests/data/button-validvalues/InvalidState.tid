<style>
.selected { background-color: red; color: white; }
</style>

<$button set="$:/state/test-btn"
	setTo="OptionA"
	default="OptionA"
	validValues="OptionA OptionB OptionC"
	selectedClass="selected"
>
	A
</$button>
<$button set="$:/state/test-btn"
	setTo="OptionB"
	default="OptionA"
	validValues="OptionA OptionB OptionC"
	selectedClass="selected"
>
	B
</$button>

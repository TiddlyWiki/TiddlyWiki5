\procedure colour-swatch(name)
\whitespace trim
<div style="display:inline-block;width:130px;margin:2px;font-size:0.65em;overflow:hidden;border-radius:3px;border:1px solid rgba(128,128,128,0.3);">
<div class={{{ [<name>addprefix[tc-palette-swatch-]] }}} style="padding:6px 4px;color:white;text-shadow:0 0 2px black;"><<name>></div>
</div>
\end

\procedure swatch-styles()
\whitespace trim
<$list filter="[{$:/palette}indexes[]]" variable="colourName">
<$let colourValue={{{ [{$:/palette}getindex<colourName>] }}}>
<$text text={{{ [<colourName>addprefix[.tc-palette-swatch-]addsuffix[ { background-color: ]addsuffix<colourValue>addsuffix[; }]] }}}/><$text text="
"/>
</$let>
</$list>
\end

<style>
<$wikify name="styles" text="<<swatch-styles>>"><<styles>></$wikify>
</style>

Current palette: ''<$text text={{$:/palette}}/>''

<div style="margin:8px 0;">
Switch palette:
<$list filter="[all[shadows+tiddlers]tag[$:/tags/Palette]sort[name]]">
<$button set="$:/palette" setTo=<<currentTiddler>> class="tc-btn-invisible" style="margin:0 4px;">
<$text text={{{ [<currentTiddler>get[name]] }}}/>
</$button>
</$list>
</div>

